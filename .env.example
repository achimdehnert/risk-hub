# Django
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/riskhub

# Tenancy
TENANT_BASE_DOMAIN=localhost
TENANT_ALLOW_LOCALHOST=1
TENANT_RESERVED_SUBDOMAINS=www

# S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=documents
S3_USE_SSL=0
S3_PUBLIC_BASE_URL=http://localhost:9000/documents

# Email
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=1
DEFAULT_FROM_EMAIL=noreply@schutztat.de

# LLM Gateway
LLM_GATEWAY_URL=http://localhost:8100
LLM_GATEWAY_TIMEOUT=120

# Redis / Celery
REDIS_URL=redis://localhost:6379/0

# ── Stripe Billing ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe Webhook Secret (https://dashboard.stripe.com/webhooks)
# Endpoint URL: https://schutztat.de/billing/webhook/
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (create in Stripe Dashboard -> Products)
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_STARTER_ANNUAL=price_...
STRIPE_PRICE_PROFESSIONAL_MONTHLY=price_...
STRIPE_PRICE_PROFESSIONAL_ANNUAL=price_...
STRIPE_PRICE_BUSINESS_MONTHLY=price_...
STRIPE_PRICE_BUSINESS_ANNUAL=price_...

# ── billing-hub Internal API (ADR-118) ───────────────────────────────────────
BILLING_INTERNAL_SECRET=change-me-shared-with-billing-hub
BILLING_HMAC_SECRET=change-me-to-a-32char-random-secret
# Optional: previous secret during key rotation
BILLING_HMAC_SECRET_PREV=
